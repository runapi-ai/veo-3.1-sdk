# RunAPI Veo3 SDK Configuration

# Required: Your RunAPI API Token
# Get this from Rails console: ApiToken.first.token
RUNAPI_API_KEY=your-api-token-here

# Optional: API Base URL (defaults to http://localhost:3000)
RUNAPI_BASE_URL=http://localhost:3000

# Required: Test Image URL for image-to-video and reference-to-video tests
# Must be a publicly accessible image URL
TEST_IMAGE_URL=https://raw.githubusercontent.com/ckenst/images-catalog/refs/heads/master/size/small_size/Starbucks%20Dog.jpg

# Optional: Enable debug logging
DEBUG=false
